COMMAND_PREFIX=!
DATA_DIR=./data
CODEX_COMMAND=codex

# Discord Bot Token 不放在项目 .env 里。
# 部署脚本会单独把它写到：
#   ~/.codex-tunning/secrets.env
# 并使用带前缀的变量名：
#   CODEX_TUNNING_DISCORD_BOT_TOKEN=...

# setup / deploy / configure 会在终端里交互式提示你填写下面这些关键项。
# 如果你已经有 OpenClaw 配置，脚本也会先尝试自动导入 Discord Token / 代理。

# 可选：限制只允许绑定这些根目录下的项目，多个路径用逗号分隔。
# 建议填写绝对路径。
# ALLOWED_WORKSPACE_ROOTS=/path/to/workspaces,/path/to/projects

# 可选：默认 Codex 配置
# 默认使用 danger-full-access，便于在 Discord 中直接读写项目文件。
DEFAULT_CODEX_MODEL=
DEFAULT_CODEX_PROFILE=
DEFAULT_CODEX_SANDBOX=danger-full-access
DEFAULT_CODEX_APPROVAL=never
DEFAULT_CODEX_SEARCH=true
DEFAULT_CODEX_SKIP_GIT_REPO_CHECK=true
DEFAULT_CODEX_ADD_DIRS=
DEFAULT_CODEX_CONFIGS=

# 可选：显式指定管理员 Discord 用户 ID，多个用逗号分隔
# DISCORD_ADMIN_USER_IDS=1234567890,9876543210

# Web 面板
WEB_ENABLED=true
WEB_BIND=0.0.0.0
WEB_PORT=3769
WEB_AUTH_TOKEN=

# 如果你有 OpenClaw 配置，scripts/macos-bridge.sh 会自动尝试从中导入：
# - Discord Bot Token（单独写入 ~/.codex-tunning/secrets.env）
# - Discord 代理（写入 OPENCLAW_DISCORD_PROXY，并在 start 时注入 HTTP_PROXY/HTTPS_PROXY）
# OPENCLAW_DISCORD_PROXY=http://127.0.0.1:7890
# 如果代理导致 Node 报 unable to get local issuer certificate：
# - start / service-run 会在检测到代理时自动启用 --use-system-ca
# - 如果系统存在 /etc/ssl/cert.pem，也会自动作为额外 CA bundle 注入
# - 如 daemon 模式仍需显式证书，可额外指定 PEM 文件
# OPENCLAW_DISCORD_CA_CERT=~/.codex-tunning/clash-ca.pem

# smoke:discord 默认会读取 OpenClaw 配置；如需改路径可单独设置
# OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json
