DISCORD_BOT_TOKEN=your-discord-bot-token
COMMAND_PREFIX=!
DATA_DIR=./data
CODEX_COMMAND=codex

# setup / deploy / configure 会在终端里交互式提示你填写下面这些关键项。
# 如果你已经有 OpenClaw 配置，脚本也会先尝试自动导入 Discord Token / 代理。

# 可选：限制只允许绑定这些根目录下的项目，多个路径用逗号分隔
# ALLOWED_WORKSPACE_ROOTS=/Users/<user>/work,/Users/<user>/projects

# 可选：默认 Codex 配置
DEFAULT_CODEX_MODEL=
DEFAULT_CODEX_PROFILE=
DEFAULT_CODEX_SANDBOX=workspace-write
DEFAULT_CODEX_APPROVAL=never
DEFAULT_CODEX_SEARCH=false
DEFAULT_CODEX_SKIP_GIT_REPO_CHECK=true
DEFAULT_CODEX_ADD_DIRS=
DEFAULT_CODEX_CONFIGS=

# 可选：显式指定管理员 Discord 用户 ID，多个用逗号分隔
# DISCORD_ADMIN_USER_IDS=1234567890,9876543210

# Web 面板
WEB_ENABLED=true
WEB_BIND=127.0.0.1
WEB_PORT=3769
WEB_AUTH_TOKEN=

# 如果你有 OpenClaw 配置，scripts/macos-bridge.sh 会自动尝试从中导入：
# - Discord Bot Token
# - Discord 代理（写入 OPENCLAW_DISCORD_PROXY，并在 start 时注入 HTTP_PROXY/HTTPS_PROXY）
# OPENCLAW_DISCORD_PROXY=http://127.0.0.1:7890

# smoke:discord 默认会读取 openclaw 配置；如需改路径可单独设置
# OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json
